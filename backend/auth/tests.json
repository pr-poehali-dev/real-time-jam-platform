{
  "tests": [
    {
      "name": "Me without token returns 401",
      "method": "GET",
      "path": "/?action=me",
      "expectedStatus": 401,
      "expectedBody": { "error": "unauthorized" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Logout without token returns ok",
      "method": "POST",
      "path": "/?action=logout",
      "expectedStatus": 200,
      "expectedBody": { "ok": true },
      "bodyMatcher": "partial"
    },
    {
      "name": "Register with missing fields returns 400",
      "method": "POST",
      "path": "/?action=register",
      "body": { "email": "", "password": "", "name": "" },
      "expectedStatus": 400,
      "bodyMatcher": "partial"
    }
  ]
}